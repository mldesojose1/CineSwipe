# ============================================================
#  CineSwipe — .gitignore
#  Stack: React + Vite + TypeScript + TailwindCSS
# ============================================================

# --- Dependencias ---
node_modules/
.pnp
.pnp.js

# --- Build / Output ---
dist/
dist-ssr/
build/
out/

# --- Cache de herramientas ---
.vite/
.cache/
.turbo/
.parcel-cache/

# --- TypeScript ---
*.tsbuildinfo

# --- Variables de entorno (¡NUNCA subir secrets!) ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editores / IDEs ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.DS_Store
Thumbs.db

# --- Sistema operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# --- Testing ---
coverage/
.nyc_output/
playwright-report/
test-results/

# --- Misc ---
*.local
*.tgz
*.zip
